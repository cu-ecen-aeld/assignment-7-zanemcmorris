#!/bin/sh
# Start-up loader for scull + misc modules

case "$1" in
  start)
    echo "Loading AESD LDD modules..."

    # Load scull (creates /dev/scull* and loads scull.ko)
    if [ -x /usr/bin/scull_load ]; then
      /usr/bin/scull_load
    else
      echo "ERROR: /usr/bin/scull_load not found or not executable"
    fi

    # Load misc modules (hello/faulty via module_load)
    if [ -x /usr/bin/module_load ]; then
      /usr/bin/module_load faulty
      /usr/bin/module_load hello
    else
      echo "ERROR: /usr/bin/module_load not found or not executable"
    fi

    ;;
  stop)
    echo "Unloading AESD LDD modules..."

    if [ -x /usr/bin/module_unload ]; then
      /usr/bin/module_unload
    fi

    if [ -x /usr/bin/scull_unload ]; then
      /usr/bin/scull_unload
    fi

    ;;
  restart)
    $0 stop
    $0 start
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac

exit 0